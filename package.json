{
  "name": "obsidian-vault-agent",
  "version": "0.1.0",
  "description": "AI agent for Obsidian",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production && cp src/styles.css .obsidian/plugins/vault-agent/styles.css",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:integration": "INTEGRATION_TEST=1 jest __tests__/integration",
    "version": "node version-bump.mjs && git add manifest.json versions.json",
    "copy:styles": "cp src/styles.css .obsidian/plugins/vault-agent/styles.css"
  },
  "keywords": [],
  "author": "cyan91",
  "license": "MIT",
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^20.0.0",
    "builtin-modules": "^3.3.0",
    "esbuild": "^0.20.0",
    "jest": "^30.2.0",
    "obsidian": "latest",
    "ts-jest": "^29.4.6",
    "tslib": "^2.8.1",
    "typescript": "^5.0.0"
  }
}
